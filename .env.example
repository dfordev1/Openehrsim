# ─── Client-side (Vite) ──────────────────────────────────────────────────────
# Exposed to the browser — use the anon (public) key only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Server-side (Vercel API routes) ─────────────────────────────────────────
# NEVER expose these to the browser.
SUPABASE_URL=                        # same value as VITE_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=           # Project Settings → API → service_role (keep secret!)

# ─── AI ───────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=MY_DEEPSEEK_API_KEY
GEMINI_API_KEY=MY_GEMINI_API_KEY

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=MY_APP_URL
